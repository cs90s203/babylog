rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in [
          'cs90s203@gmail.com',
          'snowy5420@gmail.com'
        ];
    }

    // Single-family app: everything lives under families/default.
    // Only the whitelisted caregiver emails above can read or write any of it.
    match /families/default/{document=**} {
      allow read, write: if isAllowed();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
