rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isDefaultFamily() {
      return request.auth != null &&
        request.auth.token.email in [
          'cs90s203@gmail.com',
          'snowy5420@gmail.com',
          'lunamamahappy@gmail.com'
        ];
    }
    function isFriendAFamily() {
      return request.auth != null &&
        request.auth.token.email in [
          'phoebe790322@gmail.com',
          'jumptoohigh@gmail.com'
        ];
    }
    function isFriendBFamily() {
      return request.auth != null &&
        request.auth.token.email in [
          'sanan282000@gmail.com'
        ];
    }
    function isFriendCFamily() {
      return request.auth != null &&
        request.auth.token.email in [
          'jennifer90131@gmail.com',
          's95321053@gmail.com'
        ];
    }

    // Multi-family app: each family lives under its own families/{id} path, with its own
    // email whitelist below — these lists must stay in sync with FAMILIES in
    // js/firebase-sync.js. A family's members can only read/write their own path; there's
    // no rule granting cross-family access, so families/default and families/friendA (etc)
    // are fully isolated from each other.
    match /families/default/{document=**} {
      allow read, write: if isDefaultFamily();
    }
    match /families/friendA/{document=**} {
      allow read, write: if isFriendAFamily();
    }
    match /families/friendB/{document=**} {
      allow read, write: if isFriendBFamily();
    }
    match /families/friendC/{document=**} {
      allow read, write: if isFriendCFamily();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
